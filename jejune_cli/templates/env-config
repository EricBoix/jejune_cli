# Non-secret defaults — safe to commit and share across developers.
# Variables set in the environment or in .jejune/env-secrets take precedence over these.

### Neo4j connection defaults (local Docker instance)
NEO4J_PORT=7687
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j

### Catalog and workspace layout
# Absolute path to the local directory holding all side-by-side jj_* clones.
JJ_ROOT_DIR=/absolute/path/to/local/clones_CHANGE_ME

### Optional: LLM observability (OTLP HTTP receiver — no API key required)
# TRACELOOP_BASE_URL=http://localhost:4318
