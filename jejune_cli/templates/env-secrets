### Neo4j credentials
NEO4J_PASSWORD=your_password_CHANGE_ME

### LLM server
#
# LLM_MODEL_URL is the Ollama base URL — the value passed to ChatOllama inside
# the inference container.  For an OpenWebUI deployment, this is always the
# server root with /ollama appended, because OpenWebUI proxies Ollama there and
# ChatOllama appends /api/chat to whatever URL it receives.
#
#   ChatOllama call:  POST <LLM_MODEL_URL>/api/chat
#
# LLM_SERVER_URL is the OpenWebUI root used for management checks
# (API key validation, model listing).  It is DERIVED automatically:
#   • if LLM_MODEL_URL ends with /ollama  →  strip it  (OpenWebUI case)
#   • otherwise                           →  use as-is  (bare Ollama case)
# Set LLM_SERVER_URL explicitly only when your server uses a non-standard path.
#
# Example for an OpenWebUI server at https://ollama-ui.example.com:
#
#   LLM_MODEL_URL=https://ollama-ui.example.com/ollama   ← required
#   # LLM_SERVER_URL is derived as https://ollama-ui.example.com
#
# LLM_INFERENCE_ENDPOINT is optional: path appended to LLM_MODEL_URL for the
# inference round-trip test. Defaults to /api/chat (what ChatOllama appends).
# Set it to /api/chat/completions to target the OpenAI-compatible endpoint.
LLM_MODEL_URL=https://your_openwebui_server_CHANGE_ME/ollama
LLM_API_KEY=sk-CHANGE_ME
LLM_MODEL_NAME=llama3:70b_CHANGE_ME
