### Neo4j credentials
NEO4J_PASSWORD=your_password_CHANGE_ME

### LLM server
#
# OpenWebUI exposes two distinct base URLs on the same host:
#
#   LLM_SERVER_URL  — the OpenWebUI root.
#                     Used by `jejune llm status` for management checks:
#                       GET  <LLM_SERVER_URL>/api/v1/auths/   (API key validation)
#                       GET  <LLM_SERVER_URL>/api/models       (model listing)
#
#   LLM_MODEL_URL   — the Ollama proxy, always at <LLM_SERVER_URL>/ollama.
#                     Used by ChatOllama in the inference container AND by
#                     `jejune llm status` for inference checks.
#                     ChatOllama appends /api/chat to this value, so the full
#                     inference URL becomes <LLM_MODEL_URL>/api/chat.
#
# Example for a server at https://ollama-ui.example.com:
#
#   LLM_SERVER_URL=https://ollama-ui.example.com
#   LLM_MODEL_URL=https://ollama-ui.example.com/ollama
#
# LLM_SERVER_URL is optional: when omitted it defaults to LLM_MODEL_URL, which
# is correct for a bare Ollama instance (no OpenWebUI in front of it).
#
# LLM_INFERENCE_ENDPOINT is optional: it is the path appended to LLM_MODEL_URL
# for the inference round-trip test. Defaults to /api/chat, matching ChatOllama.
# Set it to /api/chat/completions when targeting the OpenAI-compatible endpoint.
LLM_SERVER_URL=https://your_openwebui_server_CHANGE_ME
LLM_MODEL_URL=https://your_openwebui_server_CHANGE_ME/ollama
LLM_API_KEY=sk-CHANGE_ME
LLM_MODEL_NAME=llama3:70b_CHANGE_ME
