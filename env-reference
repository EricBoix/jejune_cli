# Template for env-secrets — copy to env-secrets and fill in real values.
# env-secrets is gitignored and must never be committed.
#
# Non-secret defaults (NEO4J_PORT, NEO4J_URI, NEO4J_USERNAME) live in env-config.
# Variables set directly in the environment take precedence over this file.

### Neo4j credentials
NEO4J_PASSWORD=your_password_CHANGE_ME

### LLM server (URL may point to a private server — keep it secret)
LLM_MODEL_URL=https://your_favorite_server_CHANGE_ME/ollama/
LLM_API_KEY=sk-CHANGE_ME
LLM_MODEL_NAME=llama3:70b_CHANGE_ME

### Catalog and workspace layout
# Absolute path to the local directory holding all side-by-side jj_* clones.
JJ_ROOT_DIR=/absolute/path/to/local/clones_CHANGE_ME

### Optional: LLM observability (OTLP HTTP receiver — no API key required)
# TRACELOOP_BASE_URL=http://localhost:4318
